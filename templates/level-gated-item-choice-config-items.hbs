<div class="lgic-pool">
  <h3>{{localize "LGIC.Config.PoolHeading"}}</h3>
  <p class="hint">{{localize "LGIC.Config.PoolHint"}}</p>

  <div class="lgic-pool-header" aria-hidden="true">
    <span></span>
    <span>min</span>
    <span>max</span>
  </div>

  <ol class="items-list lgic-items-list">
    {{#each items}}
      <li class="item lgic-item" data-index="{{@index}}" data-item-uuid="{{data.uuid}}">
        <input type="hidden" name="configuration.pool.{{@index}}.uuid" value="{{data.uuid}}">

        <div class="lgic-item-link">
          {{{ dnd5e-linkForUuid data.uuid renderBroken=true }}}
        </div>

        <input class="lgic-level-input" type="number" name="configuration.pool.{{@index}}.minLevel" value="{{minLevel}}" min="0" step="1" aria-label="{{localize 'LGIC.Config.MinLevel'}}">

        <input class="lgic-level-input" type="number" name="configuration.pool.{{@index}}.maxLevel" value="{{maxLevel}}" min="0" step="1" placeholder="{{localize 'LGIC.Config.NoMaximum'}}" aria-label="{{localize 'LGIC.Config.MaxLevel'}}">
      </li>
    {{/each}}
  </ol>
</div>
