<div class="lgic-pool">
  <h3>{{localize "LGIC.Config.PoolHeading"}}</h3>
  <p class="hint">{{localize "LGIC.Config.PoolHint"}}</p>

  <ol class="items-list lgic-items-list">
    {{#each items}}
      <li class="item lgic-item" data-index="{{@index}}">
        <input type="hidden" name="pool.{{@index}}.uuid" value="{{data.uuid}}">

        <div class="lgic-item-link">
          {{{ dnd5e-linkForUuid data.uuid renderBroken=true }}}
        </div>

        <div class="form-group lgic-level-field">
          <label>{{localize "LGIC.Config.MinLevel"}}</label>
          <input type="number" name="pool.{{@index}}.minLevel" value="{{data.minLevel}}" min="0" step="1">
        </div>

        <div class="form-group lgic-level-field">
          <label>{{localize "LGIC.Config.MaxLevel"}}</label>
          <input type="number" name="pool.{{@index}}.maxLevel" value="{{data.maxLevel}}" min="0" step="1" placeholder="{{localize 'LGIC.Config.NoMaximum'}}">
        </div>
      </li>
    {{/each}}
  </ol>
</div>
