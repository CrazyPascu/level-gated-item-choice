<div class="lgic-pool">
  <h3>{{localize "LGIC.Config.PoolHeading"}}</h3>
  <p class="hint">{{localize "LGIC.Config.PoolHint"}}</p>

  <div class="lgic-pool-link-settings">
    <div class="form-group">
      <label>{{localize "LGIC.Config.PoolRole"}}</label>
      <div class="form-fields">
        <select name="configuration.poolRole">
          {{#each poolRoleOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">{{localize "LGIC.Config.PoolRoleHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "LGIC.Config.PoolId"}}</label>
      <div class="form-fields">
        <input type="text" name="configuration.poolId" value="{{poolId}}" placeholder="eldritch-invocations">
      </div>
      <p class="hint">{{localize "LGIC.Config.PoolIdHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "LGIC.Config.ParentPoolId"}}</label>
      <div class="form-fields">
        <input type="text" name="configuration.parentPoolId" value="{{parentPoolId}}" placeholder="eldritch-invocations">
      </div>
      <p class="hint">{{localize "LGIC.Config.ParentPoolIdHint"}}</p>
    </div>
  </div>

  <div class="lgic-level-grid">
    {{#each levelSections}}
      <details class="lgic-level-section" data-lgic-level="{{level}}" {{#if open}}open{{/if}}>
        <summary class="lgic-level-header">
          <span class="lgic-level-title">{{label}}</span>
          <span class="lgic-level-header-right">
            <span class="lgic-level-count">{{items.length}}</span>
            <i class="fa-solid fa-chevron-down lgic-toggle-icon" inert></i>
          </span>
        </summary>

        <div class="lgic-level-body">
        <ol class="items-list lgic-items-list">
          {{#each items}}
            <li class="item lgic-item draggable" draggable="true" data-index="{{poolIndex}}" data-item-uuid="{{data.uuid}}">
              <input type="hidden" name="configuration.pool.{{poolIndex}}.uuid" value="{{data.uuid}}">
              <input type="hidden" name="configuration.pool.{{poolIndex}}.minLevel" value="{{minLevel}}">

              <div class="lgic-item-link">
                {{{ dnd5e-linkForUuid data.uuid renderBroken=true }}}
              </div>

              <button type="button" class="unbutton control-button lgic-delete" data-action="deleteItem" data-tooltip="DND5E.Delete">
                <i class="fa-solid fa-trash" inert></i>
              </button>
            </li>
          {{/each}}
        </ol>

        <div class="lgic-drop-hint">
          {{dropLabel}}
        </div>
        </div>
      </details>
    {{/each}}
  </div>

  {{#if showContainerWarning}}
    <p class="hint warning">{{localize "DND5E.ADVANCEMENT.ItemGrant.Warning.Container"}}</p>
  {{/if}}
</div>
